# Vaultfire Environment Variables
# Copy this file to .env and fill in your values — never commit .env

# Required for write operations (registerAgent, createBond)
PRIVATE_KEY=your_private_key_here

# Optional: OpenAI API key (for examples)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API key (for examples)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
